# Copy this to .env.prod on your Droplet and fill in real values.
# This file is checked in — never commit .env.prod itself.

# ── Database ─────────────────────────────────────────────────────────────────
DB_USERNAME=libraio
DB_PASSWORD=change_me_strong_password
DB_NAME=book_app_production

# ── Rails ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN/api/v1
FRONTEND_URL=https://YOUR_DOMAIN

# ── External APIs ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ISBNDB_API_KEY=

# ── Email (SendGrid or any SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
