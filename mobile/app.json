{
  "expo": {
    "name": "WellRead",
    "slug": "libraio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "libraio",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.libraio.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "WellRead uses your camera to scan book barcodes so you can quickly add books to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D1A0F"
      },
      "package": "com.libraio.app",
      "versionCode": 1,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D1A0F",
          "image": "./assets/images/splash.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3000/api/v1"
    }
  }
}
