<!-- Libraio Password Reset Email -->
<table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0D1A0F;padding:40px 16px;">
  <tr>
    <td align="center">
      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:520px;">

        <!-- Logo -->
        <tr>
          <td align="center" style="padding-bottom:32px;">
            <table cellpadding="0" cellspacing="0">
              <tr>
                <!-- Book spine icon -->
                <td style="padding-right:10px;vertical-align:middle;">
                  <div style="width:28px;height:36px;background-color:#C9A84C;border-radius:2px 4px 4px 2px;display:inline-block;"></div>
                </td>
                <td style="vertical-align:middle;">
                  <span style="font-size:26px;font-weight:700;color:#EDE0C4;letter-spacing:-0.5px;font-family:Georgia,serif;">Libraio</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Card -->
        <tr>
          <td style="background-color:#18231A;border:1px solid rgba(237,224,196,0.12);border-radius:20px;padding:40px 36px;">

            <!-- Icon -->
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center" style="padding-bottom:24px;">
                  <div style="width:52px;height:52px;background-color:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.45);border-radius:50%;display:inline-block;text-align:center;line-height:52px;font-size:22px;">
                    🔑
                  </div>
                </td>
              </tr>
            </table>

            <!-- Heading -->
            <h1 style="margin:0 0 10px;font-size:24px;font-weight:700;color:#EDE0C4;text-align:center;font-family:Georgia,serif;">Reset your password</h1>

            <!-- Body text -->
            <p style="margin:0 0 8px;font-size:15px;color:rgba(237,224,196,0.75);text-align:center;line-height:1.6;">
              Hi <strong style="color:#EDE0C4;"><%= @user.display_name.presence || @user.username %></strong>,
            </p>
            <p style="margin:0 0 32px;font-size:15px;color:rgba(237,224,196,0.75);text-align:center;line-height:1.6;">
              We received a request to reset your Libraio password. Click the button below and you'll be back to your reading list in no time.
            </p>

            <!-- CTA Button -->
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center" style="padding-bottom:28px;">
                  <a href="<%= @reset_url %>"
                     style="display:inline-block;background-color:#C9A84C;color:#1A1205;font-size:15px;font-weight:700;text-decoration:none;padding:14px 36px;border-radius:50px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                    Reset Password
                  </a>
                </td>
              </tr>
            </table>

            <!-- Expiry note -->
            <p style="margin:0 0 24px;font-size:13px;color:rgba(237,224,196,0.45);text-align:center;">
              This link expires in <strong style="color:rgba(237,224,196,0.65);">2 hours</strong>.
            </p>

            <!-- Divider -->
            <hr style="border:none;border-top:1px solid rgba(237,224,196,0.1);margin:0 0 24px;" />

            <!-- Fallback URL -->
            <p style="margin:0;font-size:12px;color:rgba(237,224,196,0.4);text-align:center;line-height:1.7;">
              If the button doesn't work, copy and paste this link:<br/>
              <a href="<%= @reset_url %>" style="color:#C9A84C;text-decoration:underline;word-break:break-all;font-size:12px;"><%= @reset_url %></a>
            </p>

          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td align="center" style="padding-top:28px;">
            <p style="margin:0 0 6px;font-size:12px;color:rgba(237,224,196,0.3);">
              If you didn't request a password reset, you can safely ignore this email.
            </p>
            <p style="margin:0;font-size:12px;color:rgba(237,224,196,0.2);">
              &copy; <%= Time.current.year %> Libraio. Your reading life, organised.
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
