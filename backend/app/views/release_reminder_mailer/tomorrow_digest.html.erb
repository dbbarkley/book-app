<!-- Libraio Release Reminder Email -->
<table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0D1A0F;padding:40px 16px;">
  <tr>
    <td align="center">
      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:520px;">

        <!-- Logo -->
        <tr>
          <td align="center" style="padding-bottom:32px;">
            <table cellpadding="0" cellspacing="0">
              <tr>
                <td style="padding-right:10px;vertical-align:middle;">
                  <div style="width:28px;height:36px;background-color:#C9A84C;border-radius:2px 4px 4px 2px;display:inline-block;"></div>
                </td>
                <td style="vertical-align:middle;">
                  <span style="font-size:26px;font-weight:700;color:#EDE0C4;letter-spacing:-0.5px;font-family:Georgia,serif;">Libraio</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Card -->
        <tr>
          <td style="background-color:#18231A;border:1px solid rgba(237,224,196,0.12);border-radius:20px;padding:40px 36px;">

            <!-- Bell icon -->
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center" style="padding-bottom:24px;">
                  <div style="width:52px;height:52px;background-color:rgba(107,173,139,0.15);border:1px solid rgba(107,173,139,0.4);border-radius:50%;display:inline-block;text-align:center;line-height:52px;font-size:22px;">
                    🔔
                  </div>
                </td>
              </tr>
            </table>

            <!-- Heading -->
            <h1 style="margin:0 0 8px;font-size:22px;font-weight:700;color:#EDE0C4;text-align:center;font-family:Georgia,serif;">
              <%= @releases.size == 1 ? 'Your book releases tomorrow' : "#{@releases.size} books you're watching release tomorrow" %>
            </h1>
            <p style="margin:0 0 32px;font-size:15px;color:rgba(237,224,196,0.65);text-align:center;line-height:1.6;">
              Hi <strong style="color:#EDE0C4;"><%= @user.display_name.presence || @user.username %></strong>, here's what you have on your radar.
            </p>

            <!-- Book list -->
            <% @releases.each do |release| %>
            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:16px;">
              <tr>
                <% if release.cover_image_url.present? %>
                <td style="width:52px;vertical-align:top;padding-right:14px;">
                  <img src="<%= release.cover_image_url&.then { |u| u.start_with?('http://', 'https://') ? u : '' } %>" width="52" alt="<%= release.title %>"
                       style="display:block;border-radius:6px;width:52px;height:auto;" />
                </td>
                <% end %>
                <td style="vertical-align:top;">
                  <p style="margin:0 0 2px;font-size:15px;font-weight:700;color:#EDE0C4;font-family:Georgia,serif;"><%= release.title %></p>
                  <p style="margin:0;font-size:13px;color:rgba(237,224,196,0.55);"><%= release.authors.first %></p>
                </td>
              </tr>
            </table>
            <% end %>

            <!-- Divider -->
            <hr style="border:none;border-top:1px solid rgba(237,224,196,0.1);margin:24px 0;" />

            <!-- CTA -->
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center">
                  <a href="<%= ENV.fetch('FRONTEND_URL', 'http://localhost:3002') %>/upcoming-releases"
                     style="display:inline-block;background-color:#6BAD8B;color:#0D1A0F;font-size:14px;font-weight:700;text-decoration:none;padding:12px 32px;border-radius:50px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                    View Upcoming Releases
                  </a>
                </td>
              </tr>
            </table>

          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td align="center" style="padding-top:28px;">
            <p style="margin:0;font-size:12px;color:rgba(237,224,196,0.25);">
              &copy; <%= Time.current.year %> Libraio. You set a reminder for <%= @releases.size == 1 ? 'this book' : 'these books' %>.
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
